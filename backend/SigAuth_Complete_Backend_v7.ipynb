        "# ================================\n",
        "# DB + Verification engine + Flask API\n",
        "# ================================\n",
        "\n",
        "from flask import Flask, request, jsonify\n",
        "from flask_cors import CORS\n",
        "import jwt\n",
        "\n",
        "DB_PATH = 'sigauth.db'\n",
        "SECRET_KEY = 'sigauth_change_this_secret'\n",
        "\n",
        "def init_db():\n",
        "    conn = sqlite3.connect(DB_PATH)\n",
        "    c = conn.cursor()\n",
        "    c.execute('''CREATE TABLE IF NOT EXISTS users (\n",
        "        id INTEGER PRIMARY KEY AUTOINCREMENT,\n",
        "        username TEXT UNIQUE NOT NULL,\n",
        "        email TEXT UNIQUE NOT NULL,\n",
        "        password_hash TEXT NOT NULL,\n",
        "        role TEXT DEFAULT 'user',\n",
        "        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n",
        "    )''')\n",
        "    c.execute('''CREATE TABLE IF NOT EXISTS reference_signatures (\n",
        "        id INTEGER PRIMARY KEY AUTOINCREMENT,\n",
        "        person_name TEXT NOT NULL,\n",
        "        image_data BLOB NOT NULL,\n",
        "        image_hash TEXT,\n",
        "        filename TEXT,\n",
        "        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n",
        "    )''')\n",
        "    c.execute('''CREATE TABLE IF NOT EXISTS verification_logs (\n",
        "        id INTEGER PRIMARY KEY AUTOINCREMENT,\n",
        "        user_id INTEGER,\n",
        "        person_name TEXT,\n",
        "        result TEXT,\n",
        "        confidence REAL,\n",
        "        similarity_score REAL,\n",
        "        tamper_score REAL,\n",
        "        details TEXT,\n",
        "        timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n",
        "    )''')\n",
        "\n",
        "    admin_pw = hashlib.sha256('admin123'.encode()).hexdigest()\n",
        "    try:\n",
        "        c.execute('INSERT INTO users (username, email, password_hash, role) VALUES (?, ?, ?, ?)', ('admin', 'admin@sigauth.com', admin_pw, 'admin'))\n",
        "    except sqlite3.IntegrityError:\n",
        "        pass\n",
        "\n",
        "    conn.commit(); conn.close()\n",
        "\n",
        "init_db()\n",
        "\n",
        "inference_tf = val_tf\n",
        "\n",
        "class VerificationEngine:\n",
        "    def __init__(self, siamese, tamper, s_th, t_th, device):\n",
        "        self.siamese = siamese.eval()\n",
        "        self.tamper = tamper.eval()\n",
        "        self.s_th = float(s_th)\n",
        "        self.t_th = float(t_th)\n",
        "        self.device = device\n",
        "\n",
        "    def decode_b64(self, image_str: str):\n",
        "        if ',' in image_str:\n",
        "            image_str = image_str.split(',', 1)[1]\n",
        "        b = base64.b64decode(image_str)\n",
        "        return b, Image.open(io.BytesIO(b)).convert('L')\n",
        "\n",
        "    def to_tensor(self, img):\n",
        "        return inference_tf(img).unsqueeze(0).to(self.device)\n",
        "\n",
        "    def verify(self, test_b64: str, reference_images_bytes: List[bytes], reference_hashes: List[str]):\n",
        "        start = time.time()\n",
        "        raw_bytes, test_img = self.decode_b64(test_b64)\n",
        "        test_hash = hashlib.md5(raw_bytes).hexdigest()\n",
        "\n",
        "        # exact match shortcut\n",
        "        if test_hash in set(reference_hashes):\n",
        "            return {\n",
        "                'result': 'authentic',\n",
        "                'confidence': 0.9999,\n",
        "                'similarity_score': 1.0,\n",
        "                'tamper_score': 0.0,\n",
        "                'processing_time_ms': int((time.time()-start)*1000),\n",
        "                'details': {\n",
        "                    'rule': 'exact_hash_match',\n",
        "                    'thresholds': {'siamese': self.s_th, 'tamper': self.t_th}\n",
        "                }\n",
        "            }\n",
        "\n",
        "        test_t = self.to_tensor(test_img)\n",
        "\n",
        "        with torch.no_grad():\n",
        "            tamper_prob = F.softmax(self.tamper(test_t), dim=1)[0, 1].item()\n",
        "            test_emb = self.siamese.forward_one(test_t)\n",
        "\n",
        "            best_sim = -1.0\n",
        "            for b in reference_images_bytes:\n",
        "                ref_img = Image.open(io.BytesIO(b)).convert('L')\n",
        "                ref_t = self.to_tensor(ref_img)\n",
        "                ref_emb = self.siamese.forward_one(ref_t)\n",
        "                sim = F.cosine_similarity(test_emb, ref_emb).item()\n",
        "                best_sim = max(best_sim, sim)\n",
        "\n",
        "        # calibrated fusion for 3-class output\n",
        "        score_auth = (best_sim - self.s_th) - 0.55 * max(0.0, tamper_prob - 0.25)\n",
        "        score_tamp = (tamper_prob - self.t_th) + 0.15 * max(0.0, best_sim - self.s_th)\n",
        "        score_forg = (self.s_th - best_sim) - 0.35 * max(0.0, tamper_prob - self.t_th)\n",
        "\n",
        "        logits = np.array([score_auth, score_forg, score_tamp], dtype=np.float32)\n",
        "        probs = np.exp(logits - logits.max()); probs = probs / probs.sum()\n",
        "\n",
        "        classes = ['authentic', 'forged', 'tampered']\n",
        "        idx = int(np.argmax(probs))\n",
        "        result = classes[idx]\n",
        "\n",
        "        # conservative anti-false-positive rule\n",
        "        if result == 'tampered' and tamper_prob < (self.t_th + 0.12):\n",
        "            result = 'forged' if best_sim < self.s_th else 'authentic'\n",
        "\n",
        "        confidence = float(np.max(probs))\n",
        "\n",
        "        return {\n",
        "            'result': result,\n",
        "            'confidence': round(confidence, 4),\n",
        "            'similarity_score': round(float(best_sim), 4),\n",
        "            'tamper_score': round(float(tamper_prob), 4),\n",
        "            'processing_time_ms': int((time.time()-start)*1000),\n",
        "            'details': {\n",
        "                'thresholds': {'siamese': round(self.s_th,4), 'tamper': round(self.t_th,4)},\n",
        "                'fusion': {'authentic': round(float(probs[0]),4), 'forged': round(float(probs[1]),4), 'tampered': round(float(probs[2]),4)},\n",
        "                'stroke_consistency': round(float(max(0.0, min(1.0, best_sim))), 4),\n",
        "                'pressure_pattern': round(float(max(0.0, min(1.0, best_sim*0.95))), 4),\n",
        "                'spatial_alignment': round(float(max(0.0, min(1.0, best_sim*0.92))), 4),\n",
        "                'pixel_anomalies': round(float(tamper_prob), 4)\n",
        "            }\n",
        "        }\n",
        "\n",
        "engine = VerificationEngine(siamese_model, tamper_model, SIAMESE_THRESHOLD, TAMPER_THRESHOLD, DEVICE)\n",
        "\n",
        "def hash_password(p):\n",
        "    return hashlib.sha256(p.encode()).hexdigest()\n",
        "\n",
        "def create_token(uid, role):\n",
        "    payload = {'user_id': uid, 'role': role, 'exp': int(time.time()) + 86400}\n",
        "    return jwt.encode(payload, SECRET_KEY, algorithm='HS256')\n",
        "\n",
        "def verify_token(token):\n",
        "    try:\n",
        "        p = jwt.decode(token, SECRET_KEY, algorithms=['HS256'])\n",
        "        return p.get('user_id'), p.get('role')\n",
        "    except:\n",
        "        return None, None\n",
        "\n",
        "app = Flask(__name__)\n",
        "CORS(app, resources={r'/*': {'origins': '*'}})\n",
        "\n",
        "def current_user():\n",
        "    auth = request.headers.get('Authorization', '')\n",
        "    if not auth.startswith('Bearer '):\n",
        "        return None\n",
        "    uid, role = verify_token(auth[7:])\n",
        "    if not uid:\n",
        "        return None\n",
        "    conn = sqlite3.connect(DB_PATH); c = conn.cursor()\n",
        "    c.execute('SELECT id, username, email, role FROM users WHERE id=?', (uid,))\n",
        "    r = c.fetchone(); conn.close()\n",
        "    if not r: return None\n",
        "    return {'id': r[0], 'username': r[1], 'email': r[2], 'role': r[3]}\n",
        "\n",
        "@app.get('/health')\n",
        "def health():\n",
        "    return jsonify({\n",
        "        'status': 'healthy',\n",
        "        'models': {'siamese': 'loaded', 'tamper': 'loaded'},\n",
        "        'thresholds': {'siamese': SIAMESE_THRESHOLD, 'tamper': TAMPER_THRESHOLD},\n",
        "        'note': 'Colab runtime must be active unless this API is deployed to always-on hosting.'\n",
        "    })\n",
        "\n",
        "@app.post('/auth/signup')\n",
        "def signup():\n",
        "    d = request.get_json(force=True)\n",
        "    username = d.get('username','').strip()\n",
        "    email = d.get('email','').strip().lower()\n",
        "    password = d.get('password','')\n",
        "    if not username or not email or len(password) < 6:\n",
        "        return jsonify({'error':'Invalid input'}), 400\n",
        "\n",
        "    conn = sqlite3.connect(DB_PATH); c = conn.cursor()\n",
        "    try:\n",
        "        c.execute('INSERT INTO users (username, email, password_hash) VALUES (?, ?, ?)', (username, email, hash_password(password)))\n",
        "        conn.commit()\n",
        "        uid = c.lastrowid\n",
        "    except sqlite3.IntegrityError:\n",
        "        conn.close()\n",
        "        return jsonify({'error':'Username/email already exists'}), 409\n",
        "    conn.close()\n",
        "    token = create_token(uid, 'user')\n",
        "    return jsonify({'token': token, 'user': {'id': uid, 'username': username, 'email': email, 'role': 'user'}})\n",
        "\n",
        "@app.post('/auth/login')\n",
        "def login():\n",
        "    d = request.get_json(force=True)\n",
        "    email = d.get('email','').strip().lower()\n",
        "    pw = d.get('password','')\n",
        "    conn = sqlite3.connect(DB_PATH); c = conn.cursor()\n",
        "    c.execute('SELECT id, username, email, password_hash, role FROM users WHERE email=?', (email,))\n",
        "    r = c.fetchone(); conn.close()\n",
        "    if not r or r[3] != hash_password(pw):\n",
        "        return jsonify({'error':'Invalid credentials'}), 401\n",
        "    token = create_token(r[0], r[4])\n",
        "    return jsonify({'token': token, 'user': {'id': r[0], 'username': r[1], 'email': r[2], 'role': r[4]}})\n",
        "\n",
        "@app.get('/persons')\n",
        "def persons():\n",
        "    conn = sqlite3.connect(DB_PATH); c = conn.cursor()\n",
        "    c.execute('SELECT MIN(id), person_name, COUNT(*) FROM reference_signatures GROUP BY person_name ORDER BY person_name')\n",
        "    rows = c.fetchall(); conn.close()\n",
        "    return jsonify({'persons': [{'id': r[0], 'person_name': r[1], 'image_count': r[2]} for r in rows]})\n",
        "\n",
        "@app.post('/verify')\n",
        "def verify_route():\n",
        "    d = request.get_json(force=True)\n",
        "    person_name = d.get('person_name', '').strip()\n",
        "    test_image = d.get('test_image', '')\n",
        "    if not person_name or not test_image:\n",
        "        return jsonify({'error':'person_name and test_image required'}), 400\n",
        "\n",
        "    conn = sqlite3.connect(DB_PATH); c = conn.cursor()\n",
        "    c.execute('SELECT image_data, COALESCE(image_hash, "") FROM reference_signatures WHERE person_name=?', (person_name,))\n",
        "    rows = c.fetchall()\n",
        "    if not rows:\n",
        "        conn.close()\n",
        "        return jsonify({'error': f'No signatures found for {person_name}'}), 404\n",
        "\n",
        "    refs = [r[0] for r in rows]\n",
        "    hashes = [r[1] for r in rows if r[1]]\n",
        "\n",
        "    result = engine.verify(test_image, refs, hashes)\n",
        "\n",
        "    user = current_user()\n",
        "    c.execute('INSERT INTO verification_logs (user_id, person_name, result, confidence, similarity_score, tamper_score, details) VALUES (?, ?, ?, ?, ?, ?, ?)',\n",
        "              (user['id'] if user else None, person_name, result['result'], result['confidence'], result['similarity_score'], result['tamper_score'], json.dumps(result['details'])))\n",
        "    conn.commit(); conn.close()\n",
        "    return jsonify(result)\n",
        "\n",
        "@app.post('/admin/signatures/add')\n",
        "def add_signature():\n",
        "    user = current_user()\n",
        "    if not user or user['role'] != 'admin':\n",
        "        return jsonify({'error':'Admin only'}), 403\n",
        "\n",
        "    person_name = request.form.get('person_name','').strip()\n",
        "    files = request.files.getlist('signatures')\n",
        "    if not person_name or not files:\n",
        "        return jsonify({'error':'person_name and signatures required'}), 400\n",
        "\n",
        "    conn = sqlite3.connect(DB_PATH); c = conn.cursor()\n",
        "    count = 0\n",
        "    for f in files:\n",
        "        b = f.read()\n",
        "        if not b: continue\n",
        "        h = hashlib.md5(b).hexdigest()\n",
        "        c.execute('INSERT INTO reference_signatures (person_name, image_data, image_hash, filename) VALUES (?, ?, ?, ?)', (person_name, b, h, f.filename))\n",
        "        count += 1\n",
        "\n",
        "    conn.commit(); conn.close()\n",
        "    return jsonify({'message': f'Added {count} signatures for {person_name}', 'count': count})\n",
        "\n",
        "print('Flask app ready.')\n"
      ]
