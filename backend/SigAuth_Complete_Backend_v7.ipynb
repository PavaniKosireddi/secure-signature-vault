      "source": [
        "# ================================\n",
        "# Parsing + datasets\n",
        "# ================================\n",
        "\n",
        "IMG_RE = re.compile(r'U(\\d+)S(\\d+)', re.IGNORECASE)\n",
        "\n",
        "def parse_svc(images):\n",
        "    users = {}\n",
        "    for p in images:\n",
        "        m = IMG_RE.search(Path(p).stem)\n",
        "        if not m:\n",
        "            continue\n",
        "        uid = int(m.group(1))\n",
        "        sid = int(m.group(2))\n",
        "        users.setdefault(uid, {'genuine': [], 'forged': []})\n",
        "        if 1 <= sid <= 20:\n",
        "            users[uid]['genuine'].append(p)\n",
        "        elif 21 <= sid <= 40:\n",
        "            users[uid]['forged'].append(p)\n",
        "    valid = {u:d for u,d in users.items() if len(d['genuine']) >= 10 and len(d['forged']) >= 8}\n",
        "    return valid\n",
        "\n",
        "svc_map = parse_svc(task1_imgs + task2_imgs)\n",
        "print('Valid SVC users:', len(svc_map))\n",
        "\n",
        "train_tf = T.Compose([\n",
        "    T.Resize((CFG['img_size'], CFG['img_size'])),\n",
        "    T.RandomAffine(degrees=8, translate=(0.05, 0.05), scale=(0.95, 1.05), shear=4),\n",
        "    T.ColorJitter(brightness=0.2, contrast=0.2),\n",
        "    T.ToTensor(),\n",
        "    T.Normalize(mean=[0.5], std=[0.5])\n",
        "])\n",
        "\n",
        "val_tf = T.Compose([\n",
        "    T.Resize((CFG['img_size'], CFG['img_size'])),\n",
        "    T.ToTensor(),\n",
        "    T.Normalize(mean=[0.5], std=[0.5])\n",
        "])\n",
        "\n",
        "def robust_clean_augment(img: Image.Image):\n",
        "    # clean-like domain randomization to prevent false tamper on real signatures\n",
        "    if random.random() < 0.35:\n",
        "        img = img.filter(ImageFilter.GaussianBlur(radius=random.uniform(0.2, 0.8)))\n",
        "    if random.random() < 0.3:\n",
        "        img = ImageEnhance.Contrast(img).enhance(random.uniform(0.9, 1.2))\n",
        "    if random.random() < 0.3:\n",
        "        img = ImageEnhance.Brightness(img).enhance(random.uniform(0.9, 1.1))\n",
        "    return img\n",
        "\n",
        "class SiamesePairsDataset(Dataset):\n",
        "    def __init__(self, svc_users, transform, pairs_per_user=120):\n",
        "        self.transform = transform\n",
        "        self.pairs = []\n",
        "        user_ids = sorted(list(svc_users.keys()))\n",
        "        for uid in user_ids:\n",
        "            g = svc_users[uid]['genuine']\n",
        "            f = svc_users[uid]['forged']\n",
        "            for _ in range(pairs_per_user // 2):\n",
        "                a, p = random.sample(g, 2)\n",
        "                self.pairs.append((a, p, 1))\n",
        "            for _ in range(pairs_per_user // 2):\n",
        "                a = random.choice(g)\n",
        "                n = random.choice(f)\n",
        "                self.pairs.append((a, n, 0))\n",
        "        random.shuffle(self.pairs)\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.pairs)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        p1, p2, y = self.pairs[idx]\n",
        "        i1 = Image.open(p1).convert('L')\n",
        "        i2 = Image.open(p2).convert('L')\n",
        "        return self.transform(i1), self.transform(i2), torch.tensor(y, dtype=torch.float32)\n",
        "\n",
        "class TamperRobustDataset(Dataset):\n",
        "    def __init__(self, clean_paths, tamper_paths, svc_users, transform, add_svc_clean=True):\n",
        "        self.transform = transform\n",
        "        self.samples = []\n",
        "\n",
        "        # class 0: clean\n",
        "        for p in clean_paths:\n",
        "            self.samples.append((p, 0, 'synthetic_clean'))\n",
        "\n",
        "        if add_svc_clean:\n",
        "            for uid in svc_users:\n",
        "                for p in svc_users[uid]['genuine'][:12]:\n",
        "                    self.samples.append((p, 0, 'svc_clean'))\n",
        "                for p in svc_users[uid]['forged'][:6]:\n",
        "                    # forged is still non-digital tamper for tamper classifier\n",
        "                    self.samples.append((p, 0, 'svc_forged_non_tamper'))\n",
        "\n",
        "        # class 1: tampered\n",
        "        for p in tamper_paths:\n",
        "            self.samples.append((p, 1, 'synthetic_tampered'))\n",
        "\n",
        "        random.shuffle(self.samples)\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.samples)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        p, y, src = self.samples[idx]\n",
        "        img = Image.open(p).convert('L')\n",
        "        if y == 0 and random.random() < 0.5:\n",
        "            img = robust_clean_augment(img)\n",
        "        return self.transform(img), torch.tensor(y, dtype=torch.long)\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": [
        "# Build train/val loaders\n",
        "siamese_full = SiamesePairsDataset(svc_map, train_tf)\n",
        "s_train_len = int(0.85 * len(siamese_full))\n",
        "s_val_len = len(siamese_full) - s_train_len\n",
        "siamese_train, siamese_val = random_split(siamese_full, [s_train_len, s_val_len])\n",
        "\n",
        "tamper_full = TamperRobustDataset(clean_imgs, tampered_imgs, svc_map, train_tf, add_svc_clean=True)\n",
        "t_train_len = int(0.85 * len(tamper_full))\n",
        "t_val_len = len(tamper_full) - t_train_len\n",
        "tamper_train, tamper_val = random_split(tamper_full, [t_train_len, t_val_len])\n",
        "\n",
        "siamese_train_loader = DataLoader(siamese_train, batch_size=CFG['batch_size'], shuffle=True, num_workers=CFG['workers'])\n",
        "siamese_val_loader = DataLoader(siamese_val, batch_size=CFG['batch_size'], shuffle=False, num_workers=CFG['workers'])\n",
        "tamper_train_loader = DataLoader(tamper_train, batch_size=CFG['batch_size'], shuffle=True, num_workers=CFG['workers'])\n",
        "tamper_val_loader = DataLoader(tamper_val, batch_size=CFG['batch_size'], shuffle=False, num_workers=CFG['workers'])\n",
        "\n",
        "print('Siamese samples:', len(siamese_full), '| Train:', s_train_len, '| Val:', s_val_len)\n",
        "print('Tamper samples:', len(tamper_full), '| Train:', t_train_len, '| Val:', t_val_len)\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": [
        "# ================================\n",
        "# Models\n",
        "# ================================\n",
        "\n",
        "class EmbeddingNet(nn.Module):\n",
        "    def __init__(self, emb_dim=256):\n",
        "        super().__init__()\n",
        "        base = models.resnet18(weights=None)\n",
        "        base.conv1 = nn.Conv2d(1, 64, kernel_size=7, stride=2, padding=3, bias=False)\n",
        "        in_f = base.fc.in_features\n",
        "        base.fc = nn.Identity()\n",
        "        self.backbone = base\n",
        "        self.head = nn.Sequential(\n",
        "            nn.Linear(in_f, 512),\n",
        "            nn.ReLU(inplace=True),\n",
        "            nn.Dropout(0.25),\n",
        "            nn.Linear(512, emb_dim)\n",
        "        )\n",
        "\n",
        "    def forward(self, x):\n",
        "        x = self.backbone(x)\n",
        "        x = self.head(x)\n",
        "        return F.normalize(x, dim=1)\n",
        "\n",
        "class SiameseNet(nn.Module):\n",
        "    def __init__(self):\n",
        "        super().__init__()\n",
        "        self.encoder = EmbeddingNet(emb_dim=256)\n",
        "\n",
        "    def forward_one(self, x):\n",
        "        return self.encoder(x)\n",
        "\n",
        "    def forward(self, x1, x2):\n",
        "        e1 = self.forward_one(x1)\n",
        "        e2 = self.forward_one(x2)\n",
        "        return e1, e2\n",
        "\n",
        "class ContrastiveLoss(nn.Module):\n",
        "    def __init__(self, margin=0.6):\n",
        "        super().__init__()\n",
        "        self.margin = margin\n",
        "\n",
        "    def forward(self, e1, e2, y):\n",
        "        dist = F.pairwise_distance(e1, e2)\n",
        "        pos = y * torch.pow(dist, 2)\n",
        "        neg = (1 - y) * torch.pow(torch.clamp(self.margin - dist, min=0.0), 2)\n",
        "        return torch.mean(pos + neg)\n",
        "\n",
        "class TamperCNN(nn.Module):\n",
        "    def __init__(self):\n",
        "        super().__init__()\n",
        "        self.features = nn.Sequential(\n",
        "            nn.Conv2d(1, 32, 3, padding=1), nn.BatchNorm2d(32), nn.ReLU(), nn.MaxPool2d(2),\n",
        "            nn.Conv2d(32, 64, 3, padding=1), nn.BatchNorm2d(64), nn.ReLU(), nn.MaxPool2d(2),\n",
        "            nn.Conv2d(64, 128, 3, padding=1), nn.BatchNorm2d(128), nn.ReLU(), nn.MaxPool2d(2),\n",
        "            nn.Conv2d(128, 256, 3, padding=1), nn.BatchNorm2d(256), nn.ReLU(), nn.MaxPool2d(2),\n",
        "            nn.Conv2d(256, 256, 3, padding=1), nn.BatchNorm2d(256), nn.ReLU(), nn.AdaptiveAvgPool2d((1,1))\n",
        "        )\n",
        "        self.classifier = nn.Sequential(\n",
        "            nn.Flatten(),\n",
        "            nn.Dropout(0.35),\n",
        "            nn.Linear(256, 128),\n",
        "            nn.ReLU(),\n",
        "            nn.Dropout(0.25),\n",
        "            nn.Linear(128, 2)\n",
        "        )\n",
        "\n",
        "    def forward(self, x):\n",
        "        return self.classifier(self.features(x))\n",
        "\n",
        "siamese_model = SiameseNet().to(DEVICE)\n",
        "tamper_model = TamperCNN().to(DEVICE)\n",
        "\n",
        "print('Models initialized.')\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": [
        "# ================================\n",
        "# Train Siamese + threshold calibration\n",
        "# ================================\n",
        "\n",
        "criterion_siamese = ContrastiveLoss(margin=0.8)\n",
        "opt_s = torch.optim.AdamW(siamese_model.parameters(), lr=CFG['siamese_lr'], weight_decay=CFG['weight_decay'])\n",
        "sch_s = torch.optim.lr_scheduler.ReduceLROnPlateau(opt_s, mode='min', factor=0.5, patience=3)\n",
        "\n",
        "best_val = 1e9\n",
        "pat = 0\n",
        "hist_s = {'train_loss': [], 'val_loss': []}\n",
        "\n",
        "for ep in range(CFG['siamese_epochs']):\n",
        "    siamese_model.train()\n",
        "    tr_losses = []\n",
        "    for x1, x2, y in siamese_train_loader:\n",
        "        x1, x2, y = x1.to(DEVICE), x2.to(DEVICE), y.to(DEVICE)\n",
        "        opt_s.zero_grad()\n",
        "        e1, e2 = siamese_model(x1, x2)\n",
        "        loss = criterion_siamese(e1, e2, y)\n",
        "        loss.backward()\n",
        "        torch.nn.utils.clip_grad_norm_(siamese_model.parameters(), 1.0)\n",
        "        opt_s.step()\n",
        "        tr_losses.append(loss.item())\n",
        "\n",
        "    siamese_model.eval()\n",
        "    va_losses = []\n",
        "    sims, ys = [], []\n",
        "    with torch.no_grad():\n",
        "        for x1, x2, y in siamese_val_loader:\n",
        "            x1, x2, y = x1.to(DEVICE), x2.to(DEVICE), y.to(DEVICE)\n",
        "            e1, e2 = siamese_model(x1, x2)\n",
        "            loss = criterion_siamese(e1, e2, y)\n",
        "            va_losses.append(loss.item())\n",
        "            s = F.cosine_similarity(e1, e2).detach().cpu().numpy()\n",
        "            sims.extend(s.tolist())\n",
        "            ys.extend(y.detach().cpu().numpy().tolist())\n",
        "\n",
        "    tr, va = float(np.mean(tr_losses)), float(np.mean(va_losses))\n",
        "    hist_s['train_loss'].append(tr); hist_s['val_loss'].append(va)\n",
        "    sch_s.step(va)\n",
        "\n",
        "    print(f'Epoch {ep+1:02d} | Siamese train {tr:.4f} | val {va:.4f} | lr {opt_s.param_groups[0]["lr"]:.6f}')\n",
        "\n",
        "    if va < best_val:\n",
        "        best_val = va\n",
        "        pat = 0\n",
        "        torch.save(siamese_model.state_dict(), 'saved_models/siamese_best.pth')\n",
        "    else:\n",
        "        pat += 1\n",
        "        if pat >= CFG['early_stop_patience']:\n",
        "            print('Early stop Siamese at', ep+1)\n",
        "            break\n",
        "\n",
        "siamese_model.load_state_dict(torch.load('saved_models/siamese_best.pth', map_location=DEVICE))\n",
        "\n",
        "# Calibrate threshold from val similarities\n",
        "siamese_model.eval()\n",
        "all_s, all_y = [], []\n",
        "with torch.no_grad():\n",
        "    for x1, x2, y in siamese_val_loader:\n",
        "        x1, x2 = x1.to(DEVICE), x2.to(DEVICE)\n",
        "        e1, e2 = siamese_model(x1, x2)\n",
        "        sim = F.cosine_similarity(e1, e2).cpu().numpy()\n",
        "        all_s.extend(sim.tolist())\n",
        "        all_y.extend(y.numpy().tolist())\n",
        "\n",
        "ths = np.linspace(0.4, 0.99, 300)\n",
        "best_t, best_f1 = 0.85, -1\n",
        "for t in ths:\n",
        "    pred = (np.array(all_s) >= t).astype(int)\n",
        "    tp = np.sum((pred == 1) & (np.array(all_y) == 1))\n",
        "    fp = np.sum((pred == 1) & (np.array(all_y) == 0))\n",
        "    fn = np.sum((pred == 0) & (np.array(all_y) == 1))\n",
        "    precision = tp / max(tp + fp, 1)\n",
        "    recall = tp / max(tp + fn, 1)\n",
        "    f1 = (2 * precision * recall) / max(precision + recall, 1e-8)\n",
        "    if f1 > best_f1:\n",
        "        best_f1, best_t = f1, float(t)\n",
        "\n",
        "SIAMESE_THRESHOLD = best_t\n",
        "print('Best Siamese threshold:', SIAMESE_THRESHOLD, '| F1:', round(best_f1, 4))\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": [
        "# ================================\n",
        "# Train Tamper model + FPR-constrained threshold\n",
        "# ================================\n",
        "\n",
        "criterion_t = nn.CrossEntropyLoss()\n",
        "opt_t = torch.optim.AdamW(tamper_model.parameters(), lr=CFG['tamper_lr'], weight_decay=CFG['weight_decay'])\n",
        "sch_t = torch.optim.lr_scheduler.ReduceLROnPlateau(opt_t, mode='max', factor=0.5, patience=3)\n",
        "\n",
        "best_acc = 0.0\n",
        "pat = 0\n",
        "hist_t = {'train_acc': [], 'val_acc': [], 'train_loss': [], 'val_loss': []}\n",
        "\n",
        "for ep in range(CFG['tamper_epochs']):\n",
        "    tamper_model.train()\n",
        "    tr_loss, tr_correct, tr_total = 0.0, 0, 0\n",
        "\n",
        "    for x, y in tamper_train_loader:\n",
        "        x, y = x.to(DEVICE), y.to(DEVICE)\n",
        "        opt_t.zero_grad()\n",
        "        out = tamper_model(x)\n",
        "        loss = criterion_t(out, y)\n",
        "        loss.backward()\n",
        "        torch.nn.utils.clip_grad_norm_(tamper_model.parameters(), 1.0)\n",
        "        opt_t.step()\n",
        "\n",
        "        tr_loss += loss.item() * x.size(0)\n",
        "        tr_correct += (out.argmax(1) == y).sum().item()\n",
        "        tr_total += x.size(0)\n",
        "\n",
        "    tamper_model.eval()\n",
        "    va_loss, va_correct, va_total = 0.0, 0, 0\n",
        "    probs_t, labels_t = [], []\n",
        "    with torch.no_grad():\n",
        "        for x, y in tamper_val_loader:\n",
        "            x, y = x.to(DEVICE), y.to(DEVICE)\n",
        "            out = tamper_model(x)\n",
        "            loss = criterion_t(out, y)\n",
        "            p = F.softmax(out, dim=1)[:, 1]\n",
        "\n",
        "            va_loss += loss.item() * x.size(0)\n",
        "            va_correct += (out.argmax(1) == y).sum().item()\n",
        "            va_total += x.size(0)\n",
        "            probs_t.extend(p.cpu().numpy().tolist())\n",
        "            labels_t.extend(y.cpu().numpy().tolist())\n",
        "\n",
        "    tr_acc = tr_correct / max(tr_total, 1)\n",
        "    va_acc = va_correct / max(va_total, 1)\n",
        "    tr_l = tr_loss / max(tr_total, 1)\n",
        "    va_l = va_loss / max(va_total, 1)\n",
        "\n",
        "    hist_t['train_acc'].append(tr_acc); hist_t['val_acc'].append(va_acc)\n",
        "    hist_t['train_loss'].append(tr_l); hist_t['val_loss'].append(va_l)\n",
        "    sch_t.step(va_acc)\n",
        "\n",
        "    print(f'Epoch {ep+1:02d} | Tamper train acc {tr_acc:.4f} | val acc {va_acc:.4f} | val loss {va_l:.4f}')\n",
        "\n",
        "    if va_acc > best_acc:\n",
        "        best_acc = va_acc\n",
        "        pat = 0\n",
        "        torch.save(tamper_model.state_dict(), 'saved_models/tamper_best.pth')\n",
        "    else:\n",
        "        pat += 1\n",
        "        if pat >= CFG['early_stop_patience']:\n",
        "            print('Early stop Tamper at', ep+1)\n",
        "            break\n",
        "\n",
        "tamper_model.load_state_dict(torch.load('saved_models/tamper_best.pth', map_location=DEVICE))\n",
        "\n",
        "# Calibrate tamper threshold to keep false positives low\n",
        "tamper_model.eval()\n",
        "all_probs, all_labels = [], []\n",
        "with torch.no_grad():\n",
        "    for x, y in tamper_val_loader:\n",
        "        x = x.to(DEVICE)\n",
        "        out = tamper_model(x)\n",
        "        p = F.softmax(out, dim=1)[:, 1].cpu().numpy()\n",
        "        all_probs.extend(p.tolist())\n",
        "        all_labels.extend(y.numpy().tolist())\n",
        "\n",
        "all_probs = np.array(all_probs)\n",
        "all_labels = np.array(all_labels)\n",
        "\n",
        "# choose highest recall with FPR <= 2%\n",
        "best_th, best_rec = 0.8, -1\n",
        "for t in np.linspace(0.3, 0.99, 300):\n",
        "    pred = (all_probs >= t).astype(int)\n",
        "    fp = np.sum((pred == 1) & (all_labels == 0))\n",
        "    tn = np.sum((pred == 0) & (all_labels == 0))\n",
        "    tp = np.sum((pred == 1) & (all_labels == 1))\n",
        "    fn = np.sum((pred == 0) & (all_labels == 1))\n",
        "    fpr = fp / max(fp + tn, 1)\n",
        "    rec = tp / max(tp + fn, 1)\n",
        "    if fpr <= 0.02 and rec > best_rec:\n",
        "        best_rec = rec\n",
        "        best_th = float(t)\n",
        "\n",
        "TAMPER_THRESHOLD = best_th\n",
        "print('Best Tamper threshold (FPR<=2%):', TAMPER_THRESHOLD, '| recall:', round(best_rec, 4), '| best val acc:', round(best_acc, 4))\n"
      ]
