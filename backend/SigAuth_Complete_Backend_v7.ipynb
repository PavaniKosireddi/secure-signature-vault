        "# ================================\n",
        "# Dataset extraction + validation\n",
        "# ================================\n",
        "\n",
        "def extract_if_found(candidates, target):\n",
        "    for p in candidates:\n",
        "        if os.path.exists(p):\n",
        "            with zipfile.ZipFile(p, 'r') as zf:\n",
        "                zf.extractall(target)\n",
        "            print('Extracted', p, '->', target)\n",
        "            return True\n",
        "    return False\n",
        "\n",
        "extract_if_found(['task1.zip', '/content/task1.zip', 'Task1.zip', '/content/Task1.zip'], 'datasets/svc2004/task1')\n",
        "extract_if_found(['task2.zip', '/content/task2.zip', 'Task2.zip', '/content/Task2.zip'], 'datasets/svc2004/task2')\n",
        "extract_if_found(['synthetic_tamper.zip', '/content/synthetic_tamper.zip'], 'datasets/tamper')\n",
        "\n",
        "def find_nested_dir(base, name):\n",
        "    direct = Path(base) / name\n",
        "    if direct.exists():\n",
        "        return str(direct)\n",
        "    for root, dirs, _ in os.walk(base):\n",
        "        if name in dirs:\n",
        "            return str(Path(root) / name)\n",
        "    return str(direct)\n",
        "\n",
        "CLEAN_DIR = find_nested_dir('datasets/tamper', 'clean')\n",
        "TAMPER_DIR = find_nested_dir('datasets/tamper', 'tampered')\n",
        "\n",
        "def list_images(folder):\n",
        "    exts = {'.png', '.jpg', '.jpeg', '.bmp'}\n",
        "    out = []\n",
        "    if os.path.exists(folder):\n",
        "        for root, _, files in os.walk(folder):\n",
        "            for f in files:\n",
        "                if Path(f).suffix.lower() in exts:\n",
        "                    out.append(str(Path(root) / f))\n",
        "    return sorted(out)\n",
        "\n",
        "task1_imgs = list_images('datasets/svc2004/task1')\n",
        "task2_imgs = list_images('datasets/svc2004/task2')\n",
        "clean_imgs = list_images(CLEAN_DIR)\n",
        "tampered_imgs = list_images(TAMPER_DIR)\n",
        "\n",
        "print('Task1:', len(task1_imgs))\n",
        "print('Task2:', len(task2_imgs))\n",
        "print('Clean:', len(clean_imgs), 'from', CLEAN_DIR)\n",
        "print('Tampered:', len(tampered_imgs), 'from', TAMPER_DIR)\n",
        "\n",
        "if len(task1_imgs) == 0 or len(task2_imgs) == 0:\n",
        "    raise RuntimeError('SVC dataset missing. Upload task1.zip and task2.zip first.')\n",
        "if len(clean_imgs) == 0 or len(tampered_imgs) == 0:\n",
        "    raise RuntimeError('Synthetic tamper dataset missing clean/tampered images.')\n"
      ]
    },
    {
      "cell_type": "code",
